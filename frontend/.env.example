# Lingo.dev Translation API Key (used by Vite — must be prefixed with VITE_)
# Get yours at https://lingo.dev/
VITE_LINGO_API_KEY=your_api_key_here

# Backend URLs (change these when deploying to cloud)
# For HTTPS deployments use https:// and wss:// respectively
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
